# =========================================================
# ApoloDigital-Dental - Environment Configuration Example
# =========================================================
# Copia este archivo a .env y reemplaza los valores con tus credenciales reales.
# NUNCA subas el archivo .env al repositorio.
# =========================================================

# ---------------------------------------------------------
# General Settings
# ---------------------------------------------------------
PROJECT_NAME="ApoloDigital-Dental"
ENVIRONMENT="development"

# ---------------------------------------------------------
# Database Configuration
# Para desarrollo local usamos SQLite.
# Para producción, cambia a PostgreSQL:
# DB_URL="postgresql+psycopg://user:password@localhost:5432/dental_db"
# ---------------------------------------------------------
DB_URL="sqlite:///./dental.db"

# ---------------------------------------------------------
# JWT Security Keys (IMPORTANT: Change these in production!)
# Genera claves seguras con: openssl rand -hex 32
# ---------------------------------------------------------
JWT_SECRET="tu-clave-secreta-super-segura-para-access-token-cambiala-en-produccion"
JWT_REFRESH_SECRET="tu-clave-secreta-super-segura-para-refresh-token-cambiala-en-produccion"

# Token expiration times (in minutes/days)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------
# CORS Settings
# En producción, especifica los dominios permitidos explícitamente.
# Ejemplo: CORS_ORIGINS='["https://tudominio.com", "https://app.tudominio.com"]'
# ---------------------------------------------------------
CORS_ORIGINS='["*"]'